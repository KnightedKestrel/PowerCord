{
  "name": "powercord",
  "version": "0.0.1",
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:bot": "pnpm --filter powercord-bot dev",
    "dev:web": "pnpm --filter powercord-web dev",
    "dev": "concurrently \"pnpm run dev:bot\" \"pnpm run dev:web\"",
    "format": "pnpm run prettier:fix && pnpm run lint:fix",
    "lint": "eslint .",
    "lint:fix": "pnpm run lint -- --fix",
    "prettier": "prettier . --check",
    "prettier:fix": "prettier . --write",
    "test:bot": "pnpm --filter powercord-bot test",
    "test:web": "pnpm --filter powercord-web test",
    "clean": "rm -rf node_modules pnpm-lock.yaml bot/node_modules web/node_modules web/.nuxt web/.output web/dist"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@parcel/watcher",
      "esbuild",
      "sharp",
      "unrs-resolver",
      "vue-demi"
    ]
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@ianvs/prettier-plugin-sort-imports": "^4.7.1",
    "@vue/compiler-sfc": "^3.5.32",
    "concurrently": "^9.2.1",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.5.0",
    "prettier": "3.8.3",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "typescript-eslint": "^8.58.2"
  }
}
